<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="rootPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.bmitracker.controller.MainController">
    <left>
        <VBox spacing="8.0" style="-fx-background-color: #2c3e50; -fx-pref-width: 180px;">
            <padding>
                <Insets top="20.0" left="10.0" right="10.0" bottom="20.0"/>
            </padding>

            <Label text="BMI 体质评估" textFill="white">
                <font>
                    <Font size="16.0" name="System Bold"/>
                </font>
            </Label>
            <Label text="与预测系统" textFill="#bdc3c7">
                <font>
                    <Font size="12.0"/>
                </font>
            </Label>

            <VBox.margin>
                <Insets bottom="20.0"/>
            </VBox.margin>

            <Button fx:id="homeButton" text="首页" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"/>
            <Button fx:id="bmiButton" text="BMI 记录" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"/>
            <Button fx:id="trendButton" text="趋势预测" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"/>
            <Button fx:id="mealButton" text="膳食推荐" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"/>
            <Button fx:id="foodButton" text="食物参考" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"/>
            <Button fx:id="profileButton" text="个人信息" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: CENTER-LEFT;"/>
            <Button fx:id="logoutButton" text="退出登录" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #e74c3c; -fx-alignment: CENTER-LEFT;"/>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea">
            <Label text="欢迎使用 BMI 体质评估与预测系统" style="-fx-font-size: 18px; -fx-text-fill: #7f8c8d;"/>
        </StackPane>
    </center>
</BorderPane>
