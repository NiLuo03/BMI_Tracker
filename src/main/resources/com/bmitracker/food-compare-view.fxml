<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bmitracker.controller.FoodCompareController"
      style="-fx-background-color: #ecf0f1;">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <Label text="食物对比">
        <font>
            <Font size="20.0" name="System Bold"/>
        </font>
    </Label>

    <Label text="选择 2~3 种食物，横向对比营养成分" textFill="#7f8c8d"/>

    <HBox spacing="15.0" alignment="CENTER_LEFT">
        <Label text="食物1：" prefWidth="50"/>
        <ComboBox fx:id="foodCombo1" prefWidth="160" promptText="请选择食物"/>
        <Label text="食物2：" prefWidth="50"/>
        <ComboBox fx:id="foodCombo2" prefWidth="160" promptText="请选择食物"/>
        <Label text="食物3：" prefWidth="50"/>
        <ComboBox fx:id="foodCombo3" prefWidth="160" promptText="请选择食物（可选）"/>
    </HBox>

    <TableView fx:id="compareTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="metricColumn" text="营养指标" prefWidth="120"/>
            <TableColumn fx:id="food1Column" text="食物1" prefWidth="120"/>
            <TableColumn fx:id="food2Column" text="食物2" prefWidth="120"/>
            <TableColumn fx:id="food3Column" text="食物3" prefWidth="120"/>
        </columns>
    </TableView>
</VBox>
