<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bmitracker.controller.BmiChartController"
      style="-fx-background-color: #ecf0f1;">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <Label text="BMI 变化趋势图">
        <font>
            <Font size="20.0" name="System Bold"/>
        </font>
    </Label>

    <Label text="BMI 折线图展示（按时间升序）" textFill="#7f8c8d"/>

    <LineChart fx:id="bmiChart" prefHeight="380.0" prefWidth="650.0" VBox.vgrow="ALWAYS">
        <xAxis>
            <CategoryAxis label="日期"/>
        </xAxis>
        <yAxis>
            <NumberAxis label="BMI" lowerBound="10" upperBound="40" tickUnit="2"/>
        </yAxis>
    </LineChart>

    <Label fx:id="hintLabel" textFill="#e74c3c" wrapText="true"/>
</VBox>
