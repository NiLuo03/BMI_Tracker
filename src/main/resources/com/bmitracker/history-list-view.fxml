<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bmitracker.controller.HistoryListController"
      style="-fx-background-color: #ecf0f1;">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <Label text="历史记录">
        <font>
            <Font size="20.0" name="System Bold"/>
        </font>
    </Label>

    <Label text="查看您所有的 BMI 测量历史" textFill="#7f8c8d"/>

    <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="dateColumn" text="日期" prefWidth="170"/>
            <TableColumn fx:id="heightColumn" text="身高(cm)" prefWidth="90"/>
            <TableColumn fx:id="weightColumn" text="体重(kg)" prefWidth="90"/>
            <TableColumn fx:id="bmiColumn" text="BMI" prefWidth="80"/>
            <TableColumn fx:id="statusColumn" text="健康区间" prefWidth="100"/>
        </columns>
    </TableView>
</VBox>
