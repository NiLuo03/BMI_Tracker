<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="12.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bmitracker.controller.TrendPredictionController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="BMI 趋势预测">
        <font>
            <Font size="20.0" name="System Bold"/>
        </font>
    </Label>

    <StackPane fx:id="chartContainer" VBox.vgrow="ALWAYS">
        <LineChart fx:id="trendChart" prefHeight="420.0" prefWidth="720.0">
            <xAxis>
                <NumberAxis label="天数 (从第1条记录开始)"/>
            </xAxis>
            <yAxis>
                <NumberAxis label="BMI" lowerBound="10" upperBound="40" tickUnit="2"/>
            </yAxis>
        </LineChart>
    </StackPane>

    <Label fx:id="equationLabel" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
    <Label fx:id="rSquaredLabel" style="-fx-font-size: 12px; -fx-text-fill: #888;"/>
    <Label fx:id="slopeLabel" style="-fx-font-size: 13px; -fx-text-fill: #555;"/>
    <Label fx:id="predictionLabel" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #1565c0;"/>
    <Label fx:id="extremeLabel" style="-fx-font-size: 13px; -fx-text-fill: #666;"/>
</VBox>
