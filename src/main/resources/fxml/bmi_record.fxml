<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="14" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bmitracker.controller.BmiController"
      styleClass="page-bmi"
      style="-fx-background-color: transparent;">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="记录" styleClass="label-heading, heading-accent"/>
    <Label text="记录身体数据与管理健康档案" styleClass="label-subheading"/>
    <Separator styleClass="separator-dark"/>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <!-- Left: input card -->
        <StackPane styleClass="record-card" HBox.hgrow="ALWAYS">
            <VBox spacing="16" styleClass="record-card-inner" style="-fx-padding: 28px 30px;">
                <VBox fx:id="bmiEmptyState" styleClass="empty-state" visible="false" managed="false">
                    <StackPane alignment="CENTER">
                        <Region styleClass="empty-shape-dot"/>
                        <Region styleClass="empty-shape-dot-inner"/>
                    </StackPane>
                    <Label text="开始记录您的身高体重数据，追踪健康变化"
                           style="-fx-font-size: 13px; -fx-text-fill: -text-tertiary; -fx-text-alignment: center;"
                           wrapText="true" maxWidth="280"/>
                </VBox>
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <Label text="身高(cm)" prefWidth="100" styleClass="field-label" style="-fx-font-size: 15px;"/>
                    <TextField fx:id="heightField" promptText="请输入身高" HBox.hgrow="ALWAYS" styleClass="text-field-dark" style="-fx-font-size: 15px;"/>
                </HBox>
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <Label text="体重(kg)" prefWidth="100" styleClass="field-label" style="-fx-font-size: 15px;"/>
                    <TextField fx:id="weightField" promptText="请输入体重" HBox.hgrow="ALWAYS" styleClass="text-field-dark" style="-fx-font-size: 15px;"/>
                </HBox>
                <Button text="记录并计算 BMI" onAction="#handleCalculate" maxWidth="Infinity" styleClass="btn-primary" style="-fx-font-size: 15px; -fx-padding: 12px 0;">
                    <VBox.margin><Insets top="8.0"/></VBox.margin>
                </Button>
            </VBox>
        </StackPane>

        <!-- Right: health profile card (clickable) -->
        <StackPane styleClass="record-card" HBox.hgrow="ALWAYS" onMouseClicked="#handleEditHealth">
            <VBox spacing="14" styleClass="record-card-inner" style="-fx-padding: 28px 30px;">
                <Label text="🫀 健康档案" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -text-primary;"/>
                <Separator styleClass="separator-dark"/>

                <VBox spacing="8">
                    <Label text="过敏原" styleClass="field-label" style="-fx-font-size: 14px;"/>
                    <FlowPane fx:id="allergenPane" hgap="8" vgap="8"/>
                    <Label fx:id="allergenEmptyLabel" text="尚未记录过敏信息" style="-fx-text-fill: -text-tertiary; -fx-font-size: 13px;"/>
                </VBox>

                <VBox spacing="8">
                    <Label text="慢性病史" styleClass="field-label" style="-fx-font-size: 14px;"/>
                    <FlowPane fx:id="diseasePane" hgap="8" vgap="8"/>
                    <Label fx:id="diseaseEmptyLabel" text="尚未记录慢性病史" style="-fx-text-fill: -text-tertiary; -fx-font-size: 13px;"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>
                <Label text="点击卡片编辑档案" style="-fx-text-fill: -text-tertiary; -fx-font-size: 12px;"/>
            </VBox>
        </StackPane>
    </HBox>
</VBox>
