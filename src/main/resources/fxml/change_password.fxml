<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="12" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bmitracker.controller.ChangePasswordController"
      style="-fx-background-color: #ecf0f1;">
    <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

    <Label text="修改密码" textFill="#2c3e50">
        <font><Font size="20.0" name="System Bold"/></font>
    </Label>

    <VBox.margin><Insets bottom="5.0"/></VBox.margin>

    <PasswordField fx:id="oldPwdField" promptText="请输入原密码" maxWidth="280"
                   style="-fx-padding: 8px;"/>
    <PasswordField fx:id="newPwdField" promptText="请输入新密码" maxWidth="280"
                   style="-fx-padding: 8px;"/>
    <PasswordField fx:id="confirmPwdField" promptText="请再次输入新密码" maxWidth="280"
                   style="-fx-padding: 8px;"/>

    <Button text="确认修改" onAction="#handleChange" maxWidth="280"
            style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10px 0;">
        <VBox.margin><Insets top="8.0"/></VBox.margin>
    </Button>

    <Button text="返回个人信息" onAction="#goBack" maxWidth="280"
            style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d;"/>
</VBox>
