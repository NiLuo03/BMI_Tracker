<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="12" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bmitracker.controller.ChangePasswordController"
      style="-fx-background-color: transparent;">
    <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

    <Label text="修改密码" styleClass="label-heading"/>
    <VBox.margin><Insets bottom="5.0"/></VBox.margin>

    <PasswordField fx:id="oldPwdField" promptText="请输入原密码" maxWidth="280" styleClass="text-field-dark"/>
    <PasswordField fx:id="newPwdField" promptText="请输入新密码" maxWidth="280" styleClass="text-field-dark"/>
    <PasswordField fx:id="confirmPwdField" promptText="请再次输入新密码" maxWidth="280" styleClass="text-field-dark"/>

    <Button text="确认修改" onAction="#handleChange" maxWidth="280" styleClass="btn-primary">
        <VBox.margin><Insets top="8.0"/></VBox.margin>
    </Button>
    <Button text="返回个人信息" onAction="#goBack" maxWidth="280" styleClass="btn-secondary"/>
</VBox>
