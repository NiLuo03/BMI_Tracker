<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="12" xmlns:fx="http://javafx.com/fxml" fx:controller="com.bmitracker.controller.ChangePasswordController">
    <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>
    <Label text="修改密码" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <PasswordField fx:id="oldPwdField" promptText="原密码"/>
    <PasswordField fx:id="newPwdField" promptText="新密码"/>
    <PasswordField fx:id="confirmPwdField" promptText="确认新密码"/>
    <Button text="确认修改" onAction="#handleChange" maxWidth="Infinity"/>
    <Button text="返回" onAction="#goBack" maxWidth="Infinity"/>
</VBox>
