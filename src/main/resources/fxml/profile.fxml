<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bmitracker.controller.ProfileController"
      style="-fx-background-color: #f0f4f3;">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="个人信息" styleClass="label-heading"/>
    <Separator styleClass="separator-dark"/>

    <HBox spacing="15"><Label text="用户ID" prefWidth="80" style="-fx-text-fill: #7f8c8d;"/><Label fx:id="userIdLabel" style="-fx-text-fill: #3d4f48;"/></HBox>
    <HBox spacing="15"><Label text="账号" prefWidth="80" style="-fx-text-fill: #7f8c8d;"/><Label fx:id="userNameLabel" style="-fx-text-fill: #3d4f48;"/></HBox>
    <HBox spacing="15"><Label text="年龄" prefWidth="80" style="-fx-text-fill: #7f8c8d;"/><TextField fx:id="ageField" prefWidth="120" styleClass="text-field-dark"/></HBox>
    <HBox spacing="15">
        <Label text="性别" prefWidth="80" style="-fx-text-fill: #7f8c8d;"/>
        <RadioButton fx:id="maleRadio" text="男" styleClass="radio-button-dark"/>
        <RadioButton fx:id="femaleRadio" text="女" styleClass="radio-button-dark"/>
    </HBox>
    <HBox spacing="15"><Label text="身高(cm)" prefWidth="80" style="-fx-text-fill: #7f8c8d;"/><TextField fx:id="heightField" prefWidth="120" styleClass="text-field-dark"/></HBox>
    <HBox spacing="15"><Label text="体重(kg)" prefWidth="80" style="-fx-text-fill: #7f8c8d;"/><TextField fx:id="weightField" prefWidth="120" styleClass="text-field-dark"/></HBox>

    <Separator styleClass="separator-dark"/>

    <Label text="膳食偏好" style="-fx-text-fill: #5a7068; -fx-font-weight: bold; -fx-font-size: 14px;"/>
    <TextField fx:id="preferencesField" prefWidth="350" promptText="如：不吃辣,少碳水,低卡" styleClass="text-field-dark"/>

    <HBox spacing="10">
        <Button text="保存修改" onAction="#handleSave" styleClass="btn-primary"/>
        <Button text="修改密码" onAction="#goToChangePassword" styleClass="btn-secondary"/>
    </HBox>
</VBox>
