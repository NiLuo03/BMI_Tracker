<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bmitracker.controller.ProfileController"
      style="-fx-background-color: #ecf0f1;">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="个人信息" textFill="#2c3e50">
        <font><Font size="20.0" name="System Bold"/></font>
    </Label>

    <Separator/>

    <HBox spacing="15"><Label text="用户ID：" prefWidth="80" style="-fx-font-weight: bold;"/><Label fx:id="userIdLabel"/></HBox>
    <HBox spacing="15"><Label text="账号：" prefWidth="80" style="-fx-font-weight: bold;"/><Label fx:id="userNameLabel"/></HBox>
    <HBox spacing="15"><Label text="年龄：" prefWidth="80" style="-fx-font-weight: bold;"/><TextField fx:id="ageField" prefWidth="120"/></HBox>
    <HBox spacing="15">
        <Label text="性别：" prefWidth="80" style="-fx-font-weight: bold;"/>
        <RadioButton fx:id="maleRadio" text="男"/>
        <RadioButton fx:id="femaleRadio" text="女"/>
    </HBox>
    <HBox spacing="15"><Label text="身高(cm)：" prefWidth="80" style="-fx-font-weight: bold;"/><TextField fx:id="heightField" prefWidth="120"/></HBox>
    <HBox spacing="15"><Label text="体重(kg)：" prefWidth="80" style="-fx-font-weight: bold;"/><TextField fx:id="weightField" prefWidth="120"/></HBox>

    <Separator/>

    <Label text="膳食偏好" textFill="#2c3e50">
        <font><Font size="15.0" name="System Bold"/></font>
    </Label>
    <TextField fx:id="preferencesField" prefWidth="350" promptText="如：不吃辣,少碳水,低卡"/>

    <HBox spacing="10">
        <Button text="保存修改" onAction="#handleSave"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14px;"/>
        <Button text="修改密码" onAction="#goToChangePassword"
                style="-fx-background-color: transparent; -fx-text-fill: #2980b9;"/>
    </HBox>
</VBox>
