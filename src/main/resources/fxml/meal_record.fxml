<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="14" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bmitracker.controller.MealRecordController"
      style="-fx-background-color: transparent;">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="膳食记录" styleClass="label-heading"/>
    <Label text="选择食物和克数，查看营养摄入汇总" styleClass="label-subheading"/>

    <!-- 餐次选择标签 -->
    <HBox spacing="6" style="-fx-padding: 4 0 0 0;">
        <Button fx:id="mealBreakfastBtn" text="🌅 早餐" onAction="#selectBreakfast"
                styleClass="meal-tab-active" prefWidth="90"/>
        <Button fx:id="mealLunchBtn" text="☀️ 午餐" onAction="#selectLunch"
                styleClass="meal-tab" prefWidth="90"/>
        <Button fx:id="mealDinnerBtn" text="🌙 晚餐" onAction="#selectDinner"
                styleClass="meal-tab" prefWidth="90"/>
        <Button fx:id="mealSnackBtn" text="🍪 加餐" onAction="#selectSnack"
                styleClass="meal-tab" prefWidth="90"/>
    </HBox>

    <!-- 搜索 -->
    <TextField fx:id="searchField" promptText="输入关键字筛选食物..."
               styleClass="text-field-dark" HBox.hgrow="ALWAYS"/>

    <!-- 食物网格 -->
    <Label fx:id="foodCountLabel" text=""
           style="-fx-font-size: 11px; -fx-text-fill: #6b7280; -fx-padding: 0 0 0 2;"/>
    <ScrollPane fitToWidth="true" prefHeight="200"
                style="-fx-background: transparent; -fx-background-color: rgba(16,185,129,0.02); -fx-background-radius: 10; -fx-border-color: rgba(16,185,129,0.06); -fx-border-radius: 10; -fx-border-width: 1;">
        <FlowPane fx:id="foodGrid" hgap="5" vgap="5" prefWrapLength="600"
                  style="-fx-padding: 12; -fx-background-color: transparent;"/>
    </ScrollPane>

    <!-- 已选 -->
    <HBox spacing="6" alignment="CENTER_LEFT" style="-fx-padding: 4 0 0 0;">
        <Label text="已选食物：" style="-fx-font-size: 12px; -fx-text-fill: #6b7280;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="🗑 清空该餐" onAction="#handleClearMeal"
                style="-fx-background-color: rgba(239,68,68,0.08); -fx-text-fill: #ef4444; -fx-font-size: 11px; -fx-padding: 2 8; -fx-background-radius: 4; -fx-cursor: hand;"/>
    </HBox>
    <ScrollPane fx:id="selectedScrollPane" fitToWidth="true" prefHeight="115"
                style="-fx-background: transparent; -fx-background-color: transparent;">
        <FlowPane fx:id="selectedFlow" hgap="6" vgap="6" prefWrapLength="600"
                  style="-fx-padding: 6; -fx-background-color: transparent;"/>
    </ScrollPane>
    <Label fx:id="mealCalLabel" text="当前餐小计：0 kcal"
           style="-fx-font-size: 12px; -fx-text-fill: #10b981; -fx-font-weight: bold;"/>

    <!-- 汇总 -->
    <Separator style="-fx-background: rgba(255,255,255,0.1);"/>
    <HBox spacing="20" alignment="CENTER_LEFT">
        <Label text="总热量：" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #d0d0d0;"/>
        <Label fx:id="totalCalLabel" text="0 kcal" styleClass="calorie-highlight"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="💾 保存记录" onAction="#handleSave" styleClass="btn-secondary" prefWidth="120"/>
        <Button text="🤖 AI 建议" onAction="#handleAiAdvice" styleClass="btn-primary" prefWidth="120"/>
    </HBox>
</VBox>
