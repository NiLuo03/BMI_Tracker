<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bmitracker.controller.MealRecordController"
      style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

    <HBox alignment="CENTER_LEFT">
        <Label text="膳食记录" styleClass="label-heading"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="记一餐" styleClass="btn-primary" onAction="#handleAddMeal"/>
    </HBox>

    <HBox fx:id="contentArea" VBox.vgrow="ALWAYS" spacing="14">
        <VBox fx:id="leftArea" spacing="8" VBox.vgrow="ALWAYS">
            <VBox fx:id="chartBox" styleClass="gradient-card">
                <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                <Canvas fx:id="chartCanvas" height="180"/>
            </VBox>

            <ScrollPane fx:id="listScroll" VBox.vgrow="ALWAYS" fitToWidth="true"
                        style="-fx-background: transparent; -fx-background-color: transparent;">
                <VBox fx:id="mealListBox" spacing="8" style="-fx-background-color: transparent;"/>
            </ScrollPane>
        </VBox>

        <VBox fx:id="rightArea" spacing="8" alignment="TOP_CENTER">
            <HBox fx:id="monthNav" alignment="CENTER_LEFT">
                <Button fx:id="prevMonthBtn" text="◀" styleClass="top-nav-btn"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="monthLabel" text="2026.07"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #111111;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="nextMonthBtn" text="▶" styleClass="top-nav-btn"/>
            </HBox>

            <VBox fx:id="calendarBox"
                  style="-fx-background-color: rgba(0,0,0,0.02);
                         -fx-background-radius: 10px;
                         -fx-border-color: rgba(0,0,0,0.06);
                         -fx-border-width: 1px;
                         -fx-border-radius: 10px;
                         -fx-padding: 10 6 6 6;">
                <GridPane fx:id="calendarGrid" hgap="0" vgap="0"
                          style="-fx-background-color: transparent;"/>
            </VBox>
        </VBox>
    </HBox>
</VBox>
