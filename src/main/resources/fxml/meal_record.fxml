<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bmitracker.controller.MealRecordController"
      styleClass="page-diet"
      style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

    <HBox alignment="CENTER_LEFT">
        <Label text="膳食记录" styleClass="label-heading, heading-accent"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="addMealBtn" text="记一餐" styleClass="btn-primary" onAction="#handleAddMeal"/>
    </HBox>

    <HBox fx:id="contentArea" VBox.vgrow="ALWAYS" spacing="14">
        <VBox fx:id="leftArea" spacing="8" VBox.vgrow="ALWAYS">
            <VBox fx:id="chartBox"
                  style="-fx-background-color: rgba(0,255,170,0.04), rgba(0,200,255,0.08),
                         linear-gradient(from 0% 0% to 0% 100%, rgba(0,255,170,0.55), rgba(0,200,255,0.40), rgba(68,0,255,0.35)),
                         #ffffff;
                         -fx-background-insets: 0, 4, 6, 8;
                         -fx-background-radius: 12px;
                         -fx-padding: 16;">
                <Canvas fx:id="chartCanvas" width="400" height="180"/>
            </VBox>

            <ScrollPane fx:id="listScroll" VBox.vgrow="ALWAYS" fitToWidth="true"
                        style="-fx-background: transparent; -fx-background-color: transparent;">
                <VBox fx:id="mealListBox" spacing="12" style="-fx-background-color: transparent;"/>
            </ScrollPane>
        </VBox>

        <VBox fx:id="rightArea" spacing="8" alignment="TOP_CENTER">
            <VBox fx:id="calendarBox"
                  style="-fx-background-color: #ffffff;
                         -fx-background-radius: 10px;
                         -fx-border-color: rgba(0,0,0,0.06);
                         -fx-border-width: 1px;
                         -fx-border-radius: 10px;
                         -fx-padding: 15 6 6 6;">
                <HBox fx:id="monthNav" alignment="CENTER_LEFT"
                      style="-fx-padding: 0 0 14 0;">
                    <Button fx:id="prevMonthBtn" text="◀" styleClass="top-nav-btn"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="monthLabel" text="2026年7月"
                           style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-text-fill: #111111;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="nextMonthBtn" text="▶" styleClass="top-nav-btn"/>
                </HBox>
                <GridPane fx:id="calendarGrid" hgap="0" vgap="0"
                          style="-fx-background-color: transparent;"/>
            </VBox>
        </VBox>
    </HBox>
</VBox>
