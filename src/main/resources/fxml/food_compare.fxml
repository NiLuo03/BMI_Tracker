<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml" fx:controller="com.bmitracker.controller.FoodCompareController">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <Label text="食物对比" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <HBox spacing="10">
        <ComboBox fx:id="foodCombo1" promptText="食物1" prefWidth="150"/>
        <ComboBox fx:id="foodCombo2" promptText="食物2" prefWidth="150"/>
        <ComboBox fx:id="foodCombo3" promptText="食物3（可选）" prefWidth="150"/>
        <Button text="对比" onAction="#handleCompare"/>
    </HBox>
    <TableView fx:id="compareTable">
        <columns>
            <TableColumn fx:id="colName" text="食物" prefWidth="100"/>
            <TableColumn fx:id="colCal" text="热量(大卡)" prefWidth="100"/>
            <TableColumn fx:id="colProtein" text="蛋白质(g)" prefWidth="100"/>
            <TableColumn fx:id="colFat" text="脂肪(g)" prefWidth="100"/>
            <TableColumn fx:id="colCarb" text="碳水(g)" prefWidth="100"/>
        </columns>
    </TableView>
</VBox>
