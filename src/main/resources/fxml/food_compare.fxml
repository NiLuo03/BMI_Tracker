<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bmitracker.controller.FoodCompareController"
      styleClass="page-food"
      style="-fx-background-color: transparent;">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="食物对比" styleClass="label-heading, heading-accent"/>
    <Label text="选择两种食物，对比营养成分与标签" styleClass="label-subheading"/>

    <TitledPane text="筛选条件（可选）" expanded="false" styleClass="filter-panel">
        <VBox spacing="8" style="-fx-padding: 10px 0;">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="分类" prefWidth="80" styleClass="field-label"/>
                <ComboBox fx:id="filterCategory" prefWidth="150" promptText="全部" styleClass="combo-box-dark"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="餐食类型" prefWidth="80" styleClass="field-label"/>
                <ComboBox fx:id="filterMealType" prefWidth="150" promptText="全部" styleClass="combo-box-dark"/>
                <Label text="口感" prefWidth="60" styleClass="field-label"/>
                <ComboBox fx:id="filterTexture" prefWidth="150" promptText="全部" styleClass="combo-box-dark"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="口味" prefWidth="80" styleClass="field-label"/>
                <ComboBox fx:id="filterFlavor" prefWidth="150" promptText="全部" styleClass="combo-box-dark"/>
                <Label text="储存方式" prefWidth="60" styleClass="field-label"/>
                <ComboBox fx:id="filterStorage" prefWidth="150" promptText="全部" styleClass="combo-box-dark"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="烹饪方式" prefWidth="80" styleClass="field-label"/>
                <ComboBox fx:id="filterCooking" prefWidth="150" promptText="全部" styleClass="combo-box-dark"/>
                <Button text="重置" onAction="#resetFilters" styleClass="btn-secondary"/>
            </HBox>
        </VBox>
    </TitledPane>

    <HBox spacing="20" alignment="CENTER">
        <ComboBox fx:id="foodCombo1" promptText="选择食物 1" prefWidth="220" styleClass="combo-box-dark"/>
        <Label text="VS" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
        <ComboBox fx:id="foodCombo2" promptText="选择食物 2" prefWidth="220" styleClass="combo-box-dark"/>
    </HBox>

    <VBox fx:id="foodEmptyState" styleClass="empty-state" visible="true" managed="true" VBox.vgrow="ALWAYS">
        <Region styleClass="empty-shape-compare"/>
        <Label text="在上方选择两种食物开始对比营养成分"
               style="-fx-font-size: 13px; -fx-text-fill: -text-tertiary; -fx-text-alignment: center;"
               wrapText="true" maxWidth="280"/>
    </VBox>

    <VBox fx:id="compareContent" spacing="0" alignment="TOP_CENTER" VBox.vgrow="ALWAYS"/>
</VBox>
