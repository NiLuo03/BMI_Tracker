<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bmitracker.controller.FoodCompareController"
      style="-fx-background-color: #ecf0f1;">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="食物对比" textFill="#2c3e50">
        <font><Font size="20.0" name="System Bold"/></font>
    </Label>
    <Label text="选择 2~3 种食物，横向对比营养成分" textFill="#7f8c8d"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <ComboBox fx:id="foodCombo1" promptText="食物1" prefWidth="150"/>
        <ComboBox fx:id="foodCombo2" promptText="食物2" prefWidth="150"/>
        <ComboBox fx:id="foodCombo3" promptText="食物3（可选）" prefWidth="150"/>
        <Button text="开始对比" onAction="#handleCompare"
                style="-fx-background-color: #2980b9; -fx-text-fill: white;"/>
    </HBox>

    <TableView fx:id="compareTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colName" text="食物" prefWidth="100" style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="colCal" text="热量(大卡/100g)" prefWidth="120" style="-fx-alignment: CENTER-RIGHT;"/>
            <TableColumn fx:id="colProtein" text="蛋白质(g)" prefWidth="100" style="-fx-alignment: CENTER-RIGHT;"/>
            <TableColumn fx:id="colFat" text="脂肪(g)" prefWidth="100" style="-fx-alignment: CENTER-RIGHT;"/>
            <TableColumn fx:id="colCarb" text="碳水(g)" prefWidth="100" style="-fx-alignment: CENTER-RIGHT;"/>
        </columns>
    </TableView>
</VBox>
