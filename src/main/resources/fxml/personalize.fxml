<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<VBox spacing="16" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bmitracker.controller.PersonalizeController"
      style="-fx-background-color: transparent;">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="个性设置" styleClass="label-heading"/>
    <Label text="点击色块直接应用背景颜色" styleClass="label-subheading"/>
    <Separator styleClass="separator-dark"/>

    <Label text="背景颜色" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>

    <FlowPane hgap="20" vgap="14">
        <VBox spacing="4" alignment="CENTER" style="-fx-cursor: hand;" onMouseClicked="#selectWhite">
            <Rectangle width="80" height="80" fill="#ffffff" arcWidth="14" arcHeight="14"
                       stroke="rgba(255,255,255,0.20)" strokeWidth="1.5"/>
            <Label text="纯白" style="-fx-font-size: 12px; -fx-text-fill: -text-secondary;"/>
        </VBox>
    </FlowPane>

    <Label fx:id="hintLabel" style="-fx-font-size: 12px; -fx-text-fill: -text-secondary;"/>
</VBox>
