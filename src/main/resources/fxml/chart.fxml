<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml" fx:controller="com.bmitracker.controller.ChartController">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <Label text="BMI 折线图" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <Label fx:id="infoLabel"/>
    <LineChart fx:id="chart" prefHeight="400" prefWidth="600">
        <xAxis><NumberAxis label="天数序号"/></xAxis>
        <yAxis><NumberAxis label="BMI值"/></yAxis>
    </LineChart>
</VBox>
