<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="12" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bmitracker.controller.PredictionController"
      style="-fx-background-color: #ecf0f1;">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="趋势预测" textFill="#2c3e50">
        <font><Font size="20.0" name="System Bold"/></font>
    </Label>

    <Button fx:id="predictBtn" text="开始预测（7天后）" onAction="#handlePredict"
            style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10px 20px;"
            maxWidth="200"/>

    <StackPane fx:id="chartContainer">
        <LineChart fx:id="chart" prefHeight="380" prefWidth="650" VBox.vgrow="ALWAYS">
            <xAxis><NumberAxis label="天数序号"/></xAxis>
            <yAxis><NumberAxis label="BMI值" lowerBound="10" upperBound="40" tickUnit="2"/></yAxis>
        </LineChart>
    </StackPane>

    <Label fx:id="equationLabel" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" wrapText="true"/>
    <Label fx:id="warningLabel" wrapText="true" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
</VBox>
