<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="12" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bmitracker.controller.PredictionController"
      style="-fx-background-color: #0d0f1a;">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="趋势预测" styleClass="label-heading"/>

    <Button fx:id="predictBtn" text="🔮 开始预测（7天后）" onAction="#handlePredict" styleClass="btn-primary" maxWidth="220"/>

    <StackPane fx:id="chartContainer">
        <LineChart fx:id="chart" prefHeight="380" prefWidth="650" VBox.vgrow="ALWAYS" styleClass="chart-dark">
            <xAxis><NumberAxis label="天数序号"/></xAxis>
            <yAxis><NumberAxis label="BMI值" lowerBound="10" upperBound="40" tickUnit="2"/></yAxis>
        </LineChart>
    </StackPane>

    <Label fx:id="equationLabel" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #d0c8f0;" wrapText="true"/>
    <Label fx:id="warningLabel" wrapText="true" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
</VBox>
