<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="12" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bmitracker.controller.PredictionController"
      style="-fx-background-color: #f0fdfa;">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="趋势预测" styleClass="label-heading"/>
    <Label text="基于最小二乘法线性回归，预测 7 天后您的 BMI 变化趋势" styleClass="label-subheading"/>

    <Button fx:id="predictBtn" text="开始预测（7天后）" onAction="#handlePredict" styleClass="btn-primary" maxWidth="240"/>

    <StackPane fx:id="chartContainer">
        <LineChart fx:id="chart" prefHeight="380" prefWidth="650" VBox.vgrow="ALWAYS" styleClass="chart-dark">
            <xAxis><NumberAxis label="记录序号（天）"/></xAxis>
            <yAxis><NumberAxis label="BMI 值" lowerBound="10" upperBound="40" tickUnit="2"/></yAxis>
        </LineChart>
    </StackPane>

    <Label fx:id="equationLabel" styleClass="equation-label" wrapText="true"/>
    <Label fx:id="warningLabel" styleClass="warning-label" wrapText="true"/>
</VBox>
