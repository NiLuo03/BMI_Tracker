<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="12" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bmitracker.controller.DietController"
      style="-fx-background-color: #0d0f1a;">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="AI 膳食推荐" styleClass="label-heading"/>
    <Label text="基于您的体质数据，AI 营养师为您定制一日三餐" styleClass="label-subheading"/>

    <Button text="🥗 生成推荐" onAction="#handleGenerate" styleClass="btn-primary" maxWidth="200"/>

    <TitledPane text="早餐" expanded="true" styleClass="glass-panel">
        <Label fx:id="breakfastLabel" text="点击上方按钮生成推荐"
               wrapText="true" style="-fx-text-fill: #c0c0e0; -fx-padding: 14px;" maxWidth="500"/>
    </TitledPane>
    <TitledPane text="午餐" expanded="true" styleClass="glass-panel">
        <Label fx:id="lunchLabel" text="点击上方按钮生成推荐"
               wrapText="true" style="-fx-text-fill: #c0c0e0; -fx-padding: 14px;" maxWidth="500"/>
    </TitledPane>
    <TitledPane text="晚餐" expanded="true" styleClass="glass-panel">
        <Label fx:id="dinnerLabel" text="点击上方按钮生成推荐"
               wrapText="true" style="-fx-text-fill: #c0c0e0; -fx-padding: 14px;" maxWidth="500"/>
    </TitledPane>
    <TitledPane text="总热量" expanded="true" styleClass="glass-panel">
        <Label fx:id="totalCalLabel" text="点击上方按钮生成推荐"
               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #88cc88; -fx-padding: 10px;"/>
    </TitledPane>
</VBox>
