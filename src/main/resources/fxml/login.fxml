<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bmitracker.controller.LoginController"
      style="-fx-background-color: #ecf0f1;">
    <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

    <Label text="BMI体质评估与预测系统" textFill="#2c3e50">
        <font><Font size="20.0" name="System Bold"/></font>
    </Label>
    <Label text="用户登录" textFill="#7f8c8d">
        <font><Font size="14.0"/></font>
    </Label>

    <VBox.margin><Insets bottom="5.0"/></VBox.margin>

    <TextField fx:id="userNameField" promptText="请输入账号" maxWidth="280"
               style="-fx-padding: 8px;"/>
    <PasswordField fx:id="passwordField" promptText="请输入密码" maxWidth="280"
                   style="-fx-padding: 8px;"/>

    <Button text="登 录" onAction="#handleLogin" maxWidth="280"
            style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10px 0;">
        <VBox.margin><Insets top="10.0"/></VBox.margin>
    </Button>

    <Hyperlink text="没有账号？去注册" onAction="#goToRegister"
               style="-fx-text-fill: #2980b9;"/>
</VBox>
