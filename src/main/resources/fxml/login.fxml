<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.canvas.Canvas?>

<VBox alignment="CENTER" spacing="0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bmitracker.controller.LoginController"
      style="-fx-background-color: #0a0a0f;">

    <!-- 粒子动效 -->
    <StackPane fx:id="particlePane" style="-fx-background-color: #0a0a0f;">
        <Canvas fx:id="particleCanvas" width="460" height="160"/>
    </StackPane>

    <!-- 表单 -->
    <VBox alignment="CENTER" spacing="10" style="-fx-background-color: #0a0a0f;">
        <padding><Insets top="0" right="44" bottom="28" left="44"/></padding>

        <Label text="BMI 体质评估与预测系统" styleClass="login-title"/>
        <Label text="科学管理，健康生活" styleClass="login-subtitle">
            <VBox.margin><Insets bottom="6"/></VBox.margin>
        </Label>

        <TextField fx:id="userNameField" promptText="账号" maxWidth="Infinity" styleClass="text-field-login"/>
        <PasswordField fx:id="passwordField" promptText="密码" maxWidth="Infinity" styleClass="text-field-login"/>

        <Button text="登 录" onAction="#handleLogin" maxWidth="Infinity" styleClass="btn-login">
            <VBox.margin><Insets top="8"/></VBox.margin>
        </Button>

        <Hyperlink text="没有账号？去注册" onAction="#goToRegister" styleClass="hyperlink-login"/>
    </VBox>
</VBox>
