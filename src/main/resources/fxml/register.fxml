<?xml version="1.0" encoding="UTF-8"?>

<?import com.bmitracker.component.TitleBar?>
<?import com.bmitracker.component.WheelPicker?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<VBox fx:id="root" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bmitracker.controller.RegisterController"
      style="-fx-background-color: #0a0a0f; -fx-background-radius: 12;">
    <clip>
        <Rectangle fx:id="rootClip" width="1200" height="800" arcWidth="24" arcHeight="24"/>
    </clip>

    <TitleBar/>

    <BorderPane VBox.vgrow="ALWAYS" style="-fx-background-color: #0a0a0f;">

    <left>
        <StackPane style="-fx-background-color: #0a0a0f;" prefWidth="660">
            <VBox alignment="CENTER" spacing="4" maxWidth="400">
                <Label text="加入我们" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.90);"/>
                <Label text="创建您的账户，开始科学管理健康" style="-fx-font-size: 15px; -fx-text-fill: rgba(255,255,255,0.40);"/>
                <VBox.margin><Insets bottom="30"/></VBox.margin>
            </VBox>
        </StackPane>
    </left>

    <center>
        <StackPane style="-fx-background-color: #0a0a0f;">
            <VBox alignment="CENTER" spacing="16" maxWidth="380">
                <VBox style="-fx-background-color: rgba(255,255,255,0.06);
                    -fx-background-radius: 16px;
                    -fx-border-color: rgba(255,255,255,0.10);
                    -fx-border-width: 1px;
                    -fx-border-radius: 16px;
                    -fx-padding: 36px 32px;" spacing="12">

                    <VBox spacing="4" alignment="CENTER">
                        <Label text="用户注册" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.90);"/>
                        <Label text="创建您的 BMI 追踪账户" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.40);"/>
                        <VBox.margin><Insets bottom="4"/></VBox.margin>
                    </VBox>

                    <TextField fx:id="userNameField" promptText="账号" styleClass="text-field-login"/>
                    <PasswordField fx:id="passwordField" promptText="密码" styleClass="text-field-login"/>
                    <PasswordField fx:id="confirmField" promptText="确认密码" styleClass="text-field-login"/>

                    <VBox alignment="CENTER" spacing="4">
                        <Label text="年龄" style="-fx-text-fill: rgba(255,255,255,0.4); -fx-font-size: 12px;"/>
                        <HBox fx:id="ageDisplayBox" alignment="CENTER_LEFT" styleClass="text-field-login" maxWidth="140"
                              style="-fx-cursor: hand; -fx-padding: 0 14;">
                            <Label fx:id="ageDisplayText" text="25" HBox.hgrow="ALWAYS"
                                   style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px;"/>
                            <Label text="▼" style="-fx-text-fill: rgba(255,255,255,0.25); -fx-font-size: 9px; -fx-padding: 0 0 0 4;"/>
                        </HBox>
                        <WheelPicker fx:id="agePicker" prefWidth="140" prefHeight="180" visible="false" managed="false"
                                     style="-fx-background-color: rgba(255,255,255,0.04); -fx-background-radius: 10px; -fx-border-color: rgba(255,255,255,0.08); -fx-border-width: 1px; -fx-border-radius: 10px;"/>
                    </VBox>

                    <fx:define>
                        <ToggleGroup fx:id="genderGroup"/>
                    </fx:define>
                    <HBox spacing="20" alignment="CENTER">
                        <RadioButton fx:id="maleRadio" text="男" selected="true" toggleGroup="$genderGroup"
                                     style="-fx-text-fill: rgba(255,255,255,0.7);"/>
                        <RadioButton fx:id="femaleRadio" text="女" toggleGroup="$genderGroup"
                                     style="-fx-text-fill: rgba(255,255,255,0.7);"/>
                    </HBox>

                    <Button text="注 册" onAction="#handleRegister" styleClass="btn-login" maxWidth="Infinity">
                        <VBox.margin><Insets top="4"/></VBox.margin>
                    </Button>

                    <Hyperlink text="已有账号？去登录" onAction="#goToLogin" styleClass="hyperlink-login"/>
                </VBox>
            </VBox>
        </StackPane>
    </center>

</BorderPane>

</VBox>
