<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="14" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bmitracker.controller.LoginController"
      style="-fx-background-color: #f0fdfa;">
    <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

    <Label text="⚡ BMI 体质评估与预测系统" textFill="#0891b2">
        <font><Font size="18.0" name="System Bold"/></font>
    </Label>
    <Label text="用户登录" textFill="#5ea8a4">
        <font><Font size="13.0"/></font>
    </Label>
    <VBox.margin><Insets bottom="5.0"/></VBox.margin>

    <TextField fx:id="userNameField" promptText="请输入账号" maxWidth="280" styleClass="text-field-dark"/>
    <PasswordField fx:id="passwordField" promptText="请输入密码" maxWidth="280" styleClass="text-field-dark"/>

    <Button text="登 录" onAction="#handleLogin" maxWidth="280" styleClass="btn-primary">
        <VBox.margin><Insets top="10.0"/></VBox.margin>
    </Button>

    <Hyperlink text="没有账号？去注册" onAction="#goToRegister" styleClass="hyperlink-dark"/>
</VBox>
