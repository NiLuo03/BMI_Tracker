<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="root" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.bmitracker.controller.QuizController"
            styleClass="page-quiz"
            style="-fx-padding: 0;">

    <VBox spacing="0">
        <!-- Prepare Area -->
        <VBox fx:id="prepareArea" spacing="20" alignment="TOP_CENTER">

            <!-- Top row: Today Stats | Wrong Book | Leaderboard -->
            <HBox spacing="12" alignment="TOP_CENTER" maxWidth="Infinity" fillHeight="false">
                <VBox fx:id="todayPanel" spacing="6" alignment="TOP_CENTER"
                      style="-fx-background-color: rgba(16,185,129,0.06); -fx-background-radius: 12px; -fx-padding: 16px;"
                      HBox.hgrow="ALWAYS">
                    <Label text="📊 今日数据" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
                    <Region style="-fx-min-height: 8;"/>
                    <HBox spacing="24" alignment="CENTER">
                        <VBox spacing="2" alignment="CENTER">
                            <Label fx:id="todayCount" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
                            <Label text="已答" style="-fx-font-size: 11px; -fx-text-fill: -text-secondary;"/>
                        </VBox>
                        <VBox spacing="2" alignment="CENTER">
                            <Label fx:id="todayAccuracy" text="-" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
                            <Label text="正确率" style="-fx-font-size: 11px; -fx-text-fill: -text-secondary;"/>
                        </VBox>
                    </HBox>
                    <Region style="-fx-min-height: 6;"/>
                    <HBox spacing="24" alignment="CENTER">
                        <VBox spacing="2" alignment="CENTER">
                            <Label fx:id="todayBest" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
                            <Label text="今日最高" style="-fx-font-size: 11px; -fx-text-fill: -text-secondary;"/>
                        </VBox>
                        <VBox spacing="2" alignment="CENTER">
                            <Label fx:id="bestEver" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
                            <Label text="历史最佳" style="-fx-font-size: 11px; -fx-text-fill: -text-secondary;"/>
                        </VBox>
                    </HBox>
                    <Region style="-fx-min-height: 6;"/>
                    <HBox spacing="24" alignment="CENTER">
                        <VBox spacing="2" alignment="CENTER">
                            <HBox spacing="4" alignment="BASELINE_CENTER">
                                <Label text="连续" style="-fx-font-size: 14px; -fx-text-fill: -text-secondary;"/>
                                <Label fx:id="todayStreak" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
                                <Label text="天" style="-fx-font-size: 14px; -fx-text-fill: -text-secondary;"/>
                            </HBox>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Wrong-Question Book -->
                <VBox fx:id="wrongBookPanel" spacing="6" alignment="TOP_CENTER"
                      style="-fx-background-color: rgba(239,68,68,0.06); -fx-background-radius: 12px; -fx-padding: 16px;"
                      HBox.hgrow="ALWAYS">
                    <Label text="📝 错题本" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #ef4444;"/>
                    <Region VBox.vgrow="ALWAYS"/>
                    <Label fx:id="wrongBookCount" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #ef4444;"/>
                    <Label text="道错题待复习" style="-fx-font-size: 12px; -fx-text-fill: -text-secondary;"/>
                    <Region VBox.vgrow="ALWAYS"/>
                    <Button fx:id="btnWrongPractice" text="错题重练" onAction="#onWrongPractice"
                            prefWidth="170" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10px; -fx-text-fill: #ef4444; -fx-background-color: rgba(239,68,68,0.1); -fx-border-color: rgba(239,68,68,0.3); -fx-border-width: 1px; -fx-border-radius: 10px; -fx-cursor: hand; -fx-padding: 8 0;"/>
                </VBox>

                <VBox fx:id="leaderboardPanel" spacing="6" alignment="TOP_CENTER"
                      style="-fx-background-color: rgba(16,185,129,0.06); -fx-background-radius: 12px; -fx-padding: 16px;"
                      HBox.hgrow="ALWAYS" minHeight="320">
                    <Label text="🏆 排行榜" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
                    <HBox spacing="4" alignment="CENTER">
                        <ToggleButton fx:id="btnWeekly" text="周榜" selected="true"
                                      styleClass="toggle-button-dark"/>
                        <ToggleButton fx:id="btnAlltime" text="总榜"
                                      styleClass="toggle-button-dark"/>
                    </HBox>
                    <ScrollPane fitToWidth="true" maxHeight="320"
                                style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                        <VBox fx:id="leaderboardList" spacing="4" alignment="TOP_CENTER"/>
                    </ScrollPane>
                </VBox>
            </HBox>

            <!-- Quiz start section -->
            <VBox spacing="16" alignment="CENTER">
                <Label text="健康问答" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #10b981;"/>
                <Label text="共二十道题目" style="-fx-font-size: 15px; -fx-text-fill: -text-secondary;"/>
                <Button text="开始问答" onAction="#onStart" styleClass="btn-primary" prefWidth="220" prefHeight="50"
                        style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-background-radius: 14px;"/>
            </VBox>
        </VBox>

        <!-- Quiz Area (with nav at bottom) -->
        <HBox fx:id="quizArea" spacing="0" visible="false" managed="false">
            <VBox spacing="14" HBox.hgrow="ALWAYS">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Button fx:id="btnQuitQuiz" text="← 退出" styleClass="btn-secondary"
                            style="-fx-font-size: 12px; -fx-padding: 3 10;"/>
                    <Label fx:id="questionNum" text="问题 1 / 20"
                           style="-fx-font-size: 14px; -fx-text-fill: #10b981; -fx-font-weight: bold;"/>
                </HBox>

                <Label fx:id="questionText" wrapText="true"
                       style="-fx-font-size: 15px; -fx-text-fill: -text-primary; -fx-line-spacing: 4;"/>

                <VBox spacing="8" VBox.vgrow="ALWAYS">
                    <RadioButton fx:id="optA" text="A." styleClass="quiz-option" maxWidth="Infinity"/>
                    <RadioButton fx:id="optB" text="B." styleClass="quiz-option" maxWidth="Infinity"/>
                    <RadioButton fx:id="optC" text="C." styleClass="quiz-option" maxWidth="Infinity"/>
                    <RadioButton fx:id="optD" text="D." styleClass="quiz-option" maxWidth="Infinity"/>
                </VBox>

                <HBox fx:id="quizNav" spacing="6" alignment="CENTER" maxWidth="Infinity"
                      style="-fx-padding: 4 0 0 0;">
                    <Button fx:id="btnPrevQ" text="◀ 上一题" styleClass="btn-secondary"/>
                    <Button fx:id="btnNextQ" text="下一题 ▶" styleClass="btn-secondary"/>
                    <Button fx:id="btnSubmitQ" text="提交答卷" styleClass="btn-primary"/>
                </HBox>
            </VBox>

            <!-- Quiz Answer Sheet -->
            <VBox fx:id="quizSheetPanel" spacing="6" alignment="TOP_CENTER" visible="false" managed="false"
                  style="-fx-padding: 0 0 0 8;">
                <ToggleButton fx:id="quizSheetToggle" text="答题卡 ▶"
                              style="-fx-background-color: rgba(16,185,129,0.1); -fx-text-fill: #10b981; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 8px; -fx-cursor: hand; -fx-padding: 6 14;"/>
                <VBox fx:id="quizSheetContent" spacing="6" alignment="TOP_CENTER" visible="false" managed="false"/>
            </VBox>
        </HBox>

        <!-- Result Area (with nav at bottom) -->
        <VBox fx:id="resultArea" spacing="10" visible="false" managed="false">
            <Button fx:id="btnBackToPrepare" text="← 返回" styleClass="btn-secondary"
                    style="-fx-font-size: 12px; -fx-padding: 3 10;"/>

            <VBox fx:id="resultContent" spacing="10" VBox.vgrow="ALWAYS"/>

            <HBox fx:id="resultNav" spacing="6" alignment="CENTER" maxWidth="Infinity"
                  style="-fx-padding: 4 0 0 0;">
                <Button fx:id="btnPrevAll" text="◀ 上一题" styleClass="btn-secondary"/>
                <Button fx:id="btnPrevW" text="◀ 上一错题" styleClass="btn-secondary"/>
                <Button fx:id="btnNextW" text="下一错题 ▶" styleClass="btn-secondary"/>
                <Button fx:id="btnNextAll" text="下一题 ▶" styleClass="btn-secondary"/>
            </HBox>
        </VBox>

        <!-- spacer fills remaining space, keeping nav close to content -->
        <Region VBox.vgrow="ALWAYS"/>
    </VBox>

    <Label fx:id="resultScore" visible="false" managed="false"/>
    <Label fx:id="resultCorrect" visible="false" managed="false"/>
    <Label fx:id="resultWrong" visible="false" managed="false"/>
    <Button fx:id="btnClose" text="返回首页" onAction="#onClose" styleClass="btn-secondary" maxWidth="200"
            visible="false" managed="false"/>
</StackPane>
