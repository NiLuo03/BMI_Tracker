<?xml version="1.0" encoding="UTF-8"?>

<?import com.bmitracker.component.TitleBar?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.shape.Rectangle?>

<StackPane fx:id="root" xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.bmitracker.controller.MainController"
           styleClass="root"
           style="-fx-background-radius: 12;">
    <clip>
        <Rectangle fx:id="rootClip" width="1200" height="800" arcWidth="24" arcHeight="24"/>
    </clip>

    <Region fx:id="backdrop" style="-fx-background-color: #ffffff;"/>

    <VBox>
        <TitleBar fx:id="titleBar"/>

        <BorderPane VBox.vgrow="ALWAYS">

        <!-- ====== 左侧侧边栏 ====== -->
        <left>
            <VBox fx:id="sidebar" style="-fx-background-color: transparent; -fx-padding: 12px 6px;" prefWidth="150" minWidth="50">

                <Button style="-fx-background-color: transparent; -fx-padding: 0;" onAction="#showProfile">
                    <graphic>
                        <HBox fx:id="avatarHBox" spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 4px 8px 6px 8px;">
                            <StackPane styleClass="user-avatar">
                        <Label fx:id="avatarLabel" text="U"/>
                    </StackPane>
                    <VBox fx:id="avatarStatusBox" spacing="1">
                        <Label fx:id="sidebarUserName" text="用户" style="-fx-text-fill: -text-primary; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <HBox spacing="4" alignment="CENTER_LEFT">
                            <Region styleClass="online-dot"/>
                            <Label text="在线" style="-fx-text-fill: -text-secondary; -fx-font-size: 10px;"/>
                        </HBox>
                    </VBox>
                </HBox>
                    </graphic>
                </Button>

                <VBox fx:id="mainMenuBox" spacing="0">
                    <Label fx:id="categoryMainLabel" text="主菜单" styleClass="sidebar-category"/>
                    <VBox fx:id="mainMenuInner" spacing="20">
                        <Button fx:id="btnHome" text=" 首页" onAction="#showHome" styleClass="sidebar-btn" maxWidth="Infinity"/>
                        <Button fx:id="btnBmi" text=" 记录" onAction="#showBmiRecord" styleClass="sidebar-btn" maxWidth="Infinity"/>
                        <Button fx:id="btnHistory" text=" 数据分析" onAction="#showHistory" styleClass="sidebar-btn" maxWidth="Infinity"/>
                        <Button fx:id="btnPredict" text=" 趋势预测" onAction="#showPrediction" styleClass="sidebar-btn" maxWidth="Infinity"/>
                    </VBox>
                </VBox>

                <VBox fx:id="sidebarSpacer" VBox.vgrow="ALWAYS"/>

                <VBox fx:id="serviceMenuBox" spacing="0">
                    <Label fx:id="categoryServiceLabel" text="生活服务" styleClass="sidebar-category"/>
                    <VBox fx:id="serviceMenuInner" spacing="20">
                        <Button fx:id="btnDiet" text=" 膳食推荐" onAction="#showDiet" styleClass="sidebar-btn" maxWidth="Infinity"/>
                        <Button fx:id="btnCompare" text=" 食物对比" onAction="#showFood" styleClass="sidebar-btn" maxWidth="Infinity"/>
                        <Button fx:id="btnRank" text=" 食物榜单" onAction="#showFoodRank" styleClass="sidebar-btn" maxWidth="Infinity"/>
                        <Button fx:id="btnMealRecord" text=" 膳食记录" onAction="#showMealRecord" styleClass="sidebar-btn" maxWidth="Infinity"/>
                        <Button fx:id="btnQuiz" text=" 健康问答" onAction="#showQuiz" styleClass="sidebar-btn" maxWidth="Infinity"/>
                    </VBox>
                </VBox>

                <VBox fx:id="sidebarBottomSpacer" VBox.vgrow="ALWAYS"/>

                <HBox spacing="0" alignment="CENTER_LEFT">
                    <Button fx:id="toggleNavBtn" text="" onAction="#toggleNav" styleClass="sidebar-btn" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <VBox.margin><Insets top="8"/></VBox.margin>
                    </Button>
                    <MenuButton fx:id="menuSettings" text="" style="-fx-background-color: transparent; -fx-text-fill: -text-secondary; -fx-font-size: 14px; -fx-padding: 6px 12px; -fx-cursor: hand; -fx-background-radius: 8px;">
                        <items>
                            <MenuItem text="个性设置" onAction="#showPersonalize"/>
                            <MenuItem text="退出登录" onAction="#showLogout"/>
                        </items>
                    </MenuButton>
                </HBox>
            </VBox>
        </left>

        <center>
            <StackPane fx:id="contentPane">
                <ScrollPane fitToWidth="true" fitToHeight="true"
                            style="-fx-background: transparent; -fx-background-color: transparent;">
                    <content>
                        <StackPane style="-fx-padding: 20px 28px 40px 28px;">
                            <StackPane fx:id="glassPanel"
                                  style="-fx-background-color: -glass-bg;
                                         -fx-background-radius: 20px;
                                         -fx-border-color: -glass-border;
                                         -fx-border-width: 1px;
                                         -fx-border-radius: 20px;
                                         -fx-padding: 24px 22px;">

                                <VBox spacing="16" fx:id="homeContent">

                                    <HBox spacing="14">
                                        <VBox spacing="14" HBox.hgrow="ALWAYS">
                                            <HBox styleClass="welcome-banner" spacing="20" alignment="CENTER_LEFT">
                                                <VBox spacing="4" HBox.hgrow="ALWAYS">
                                                    <Label fx:id="welcomeLabel" text="欢迎回来" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -text-primary;"/>
                                                    <Label fx:id="bmiStatusLabel" text="BMI -- | 暂无数据" style="-fx-font-size: 13px; -fx-text-fill: -text-secondary;"/>
                                                </VBox>
                                                <VBox spacing="2" alignment="CENTER_RIGHT">
                                                    <Label fx:id="trendLabel" style="-fx-font-size: 12px; -fx-text-fill: -text-secondary;"/>
                                                </VBox>
                                            </HBox>

                                            <!-- Hero BMI card (full-width) -->
                                            <StackPane styleClass="hero-bmi-card">
                                                <HBox spacing="24" alignment="CENTER_LEFT" style="-fx-padding: 22px 28px;">
                                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                                        <Label text="BMI 记录" styleClass="hero-bmi-title"/>
                                                        <HBox spacing="12" alignment="CENTER_LEFT">
                                                            <Label fx:id="heroBmiValue" text="--" styleClass="hero-bmi-number"/>
                                                            <Label fx:id="heroBmiStatus" text="暂无数据" styleClass="hero-bmi-status"/>
                                                        </HBox>
                                                        <Label fx:id="lastRecordLabel" text="" styleClass="last-record-label"/>
                                                    </VBox>
                                                    <VBox spacing="8" alignment="CENTER_RIGHT">
                                                        <HBox spacing="8" alignment="CENTER">
                                                            <TextField fx:id="homeHeightField" promptText="身高(cm)" prefWidth="100" styleClass="text-field-dark"/>
                                                            <TextField fx:id="homeWeightField" promptText="体重(kg)" prefWidth="100" styleClass="text-field-dark"/>
                                                            <Button text="记录" onAction="#handleHomeRecord" styleClass="btn-primary" style="-fx-font-size: 13px; -fx-padding: 8px 16px;"/>
                                                        </HBox>
                                                        <Label fx:id="weightChangeLabel" text="" styleClass="weight-change-label"/>
                                                    </VBox>
                                                </HBox>
                                            </StackPane>

                                            <!-- 参数统计 -->
                                            <HBox spacing="10" HBox.hgrow="ALWAYS">
                                                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER">
                                                    <Label text="平均 BMI" styleClass="stat-label"/>
                                                    <Label fx:id="statAvgBmi" text="--" styleClass="stat-value"/>
                                                </VBox>
                                                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER">
                                                    <Label text="最高 BMI" styleClass="stat-label"/>
                                                    <Label fx:id="statMaxBmi" text="--" styleClass="stat-value stat-value-red"/>
                                                </VBox>
                                                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER">
                                                    <Label text="最低 BMI" styleClass="stat-label"/>
                                                    <Label fx:id="statMinBmi" text="--" styleClass="stat-value stat-value-green"/>
                                                </VBox>
                                                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" alignment="CENTER">
                                                    <Label text="健康天数" styleClass="stat-label"/>
                                                    <Label fx:id="statHealthyDays" text="--" styleClass="stat-value"/>
                                                </VBox>
                                            </HBox>

                                            <!-- Health zone visual + BMI mini chart -->
                                            <HBox spacing="14" HBox.hgrow="ALWAYS" prefHeight="120">
                                                <StackPane styleClass="zone-card" HBox.hgrow="ALWAYS">
                                                    <VBox spacing="8" style="-fx-padding: 14px 18px;">
                                                        <Label text="BMI 健康区间" styleClass="zone-card-title"/>
                                                        <StackPane fx:id="zoneTrack" styleClass="zone-track">
                                                            <Region styleClass="zone-track-bg"/>
                                                            <Region fx:id="zoneIndicator" styleClass="zone-indicator"/>
                                                        </StackPane>
                                                        <Label fx:id="zoneDescription" text="记录体重数据以查看区间" styleClass="zone-desc"/>
                                                    </VBox>
                                                </StackPane>
                                                <StackPane styleClass="mini-chart-card" HBox.hgrow="ALWAYS" prefWidth="280">
                                                    <VBox spacing="4" style="-fx-padding: 14px 18px;">
                                                        <Label text="BMI 趋势" styleClass="mini-chart-title"/>
                                                        <LineChart fx:id="miniChart" styleClass="mini-chart"
                                                                  createSymbols="true" legendVisible="false"
                                                                  animated="false" horizontalGridLinesVisible="false"
                                                                  verticalGridLinesVisible="false"
                                                                  alternativeRowFillVisible="false"
                                                                  alternativeColumnFillVisible="false"
                                                                  prefHeight="80">
                                                            <xAxis>
                                                                <NumberAxis fx:id="miniXAxis" tickLabelsVisible="false" tickMarkVisible="false" minorTickVisible="false"/>
                                                            </xAxis>
                                                            <yAxis>
                                                                <NumberAxis fx:id="miniYAxis" tickLabelsVisible="false" tickMarkVisible="false" minorTickVisible="false"/>
                                                            </yAxis>
                                                        </LineChart>
                                                        <Label fx:id="miniChartEmpty" text="至少2条记录后显示趋势" styleClass="mini-chart-empty"/>
                                                    </VBox>
                                                </StackPane>
                                            </HBox>

                                             <!-- Slogan bar -->
                                             <HBox styleClass="slogan-bar" alignment="CENTER" onMouseClicked="#onSloganClick">
                                                 <Label fx:id="sloganLabel" text="记录第一次体重数据，开启健康之旅！" styleClass="slogan-text"/>
                                             </HBox>
                                        </VBox>

                                        <!-- Data dashboard (right sidebar) -->
                                        <VBox prefWidth="240" styleClass="data-dashboard" spacing="0">
                                            <Label text="数据看板" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: -text-secondary; -fx-padding: 0 0 12 0;"/>
                                            <HBox styleClass="data-row" alignment="CENTER_LEFT"><VBox HBox.hgrow="ALWAYS"><Label text="最新 BMI" styleClass="data-label"/></VBox><Label fx:id="dashBmi" text="--" styleClass="data-value"/></HBox>
                                            <HBox styleClass="data-row" alignment="CENTER_LEFT"><VBox HBox.hgrow="ALWAYS"><Label text="健康区间" styleClass="data-label"/></VBox><Label fx:id="dashStatus" text="--" styleClass="data-value-green"/></HBox>
                                            <HBox styleClass="data-row" alignment="CENTER_LEFT"><VBox HBox.hgrow="ALWAYS"><Label text="建议体重" styleClass="data-label"/></VBox><Label fx:id="dashIdealWeight" text="-- kg" styleClass="data-value"/></HBox>
                                            <HBox styleClass="data-row" alignment="CENTER_LEFT"><VBox HBox.hgrow="ALWAYS"><Label text="记录次数" styleClass="data-label"/></VBox><Label fx:id="dashRecords" text="0" styleClass="data-value"/></HBox>
                                            <HBox styleClass="data-row-last" alignment="CENTER_LEFT"><VBox HBox.hgrow="ALWAYS"><Label text="趋势方向" styleClass="data-label"/></VBox><Label fx:id="dashTrend" text="--" styleClass="data-value"/></HBox>
                                        </VBox>
                                    </HBox>

                                </VBox>
                            </StackPane>
                        </StackPane>
                    </content>
                </ScrollPane>
            </StackPane>
        </center>
    </BorderPane>
    </VBox>

</StackPane>
