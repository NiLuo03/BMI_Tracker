<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml" fx:controller="com.bmitracker.controller.FoodRankController">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <Label text="食物榜单（低卡推荐）" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <HBox spacing="10">
        <Label text="选择分类："/>
        <ComboBox fx:id="categoryCombo" promptText="请选择分类" prefWidth="150"/>
    </HBox>
    <TableView fx:id="rankTable">
        <columns>
            <TableColumn fx:id="colName" text="食物" prefWidth="120"/>
            <TableColumn fx:id="colCal" text="热量(大卡)" prefWidth="100"/>
            <TableColumn fx:id="colProtein" text="蛋白质(g)" prefWidth="100"/>
            <TableColumn fx:id="colFat" text="脂肪(g)" prefWidth="100"/>
            <TableColumn fx:id="colCarb" text="碳水(g)" prefWidth="100"/>
        </columns>
    </TableView>
</VBox>
