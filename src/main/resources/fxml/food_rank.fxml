<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bmitracker.controller.FoodRankController"
      style="-fx-background-color: #ecf0f1;">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

    <Label text="食物榜单（低卡推荐）" textFill="#2c3e50">
        <font><Font size="20.0" name="System Bold"/></font>
    </Label>
    <Label text="按分类查看低卡食物排名" textFill="#7f8c8d"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="选择分类："/>
        <ComboBox fx:id="categoryCombo" promptText="请选择分类" prefWidth="150"/>
    </HBox>

    <TableView fx:id="rankTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colName" text="食物" prefWidth="130"/>
            <TableColumn fx:id="colCal" text="热量(大卡/100g)" prefWidth="130" style="-fx-alignment: CENTER-RIGHT;"/>
            <TableColumn fx:id="colProtein" text="蛋白质(g)" prefWidth="100" style="-fx-alignment: CENTER-RIGHT;"/>
            <TableColumn fx:id="colFat" text="脂肪(g)" prefWidth="100" style="-fx-alignment: CENTER-RIGHT;"/>
            <TableColumn fx:id="colCarb" text="碳水(g)" prefWidth="100" style="-fx-alignment: CENTER-RIGHT;"/>
        </columns>
    </TableView>
</VBox>
